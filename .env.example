# =====================================================================
#  IMSGAUTOBLUEBUBBLES — environment variables
#  Copy to .env.local for local dev. Set the same vars in Vercel.
#  NEVER commit real secrets. Only NEXT_PUBLIC_* are exposed to browser.
# =====================================================================

# --- Supabase (project settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS. NEVER expose to the browser / never prefix NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE=your-service-role-key

# The single app user's auth.users UUID. Used by the webhook & cron (which have
# no user session) to stamp owner_id so rows are visible to you via RLS.
# Get it after you create your login: Supabase → Authentication → Users → copy ID.
APP_OWNER_ID=00000000-0000-0000-0000-000000000000

# --- BlueBubbles bridge (server-only) ---
# Public HTTPS base URL of your BlueBubbles server (Cloudflare tunnel).
# If you use the self-healing URL feature, this is just the initial/fallback value;
# the live URL is also stored in the DB (app_settings.bb_url) and auto-updated.
BB_URL=https://your-tunnel.trycloudflare.com
# The BlueBubbles server password.
BB_PASSWORD=your-bluebubbles-password

# --- Webhook auth (server-only) ---
# Random string you generate. Append as ?secret=... on the webhook URL you paste
# into BlueBubbles (API & Webhooks). The route rejects mismatches.
WEBHOOK_SECRET=generate-a-long-random-string

# --- Cron / pump auth (server-only) ---
# Vercel Cron automatically sends `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=generate-a-long-random-string
# Secret for an EXTERNAL pinger (e.g. launchd on the Mac, or cron-job.org) that
# hits /api/cron/pump every minute. Lets you rotate it without touching Vercel.
PUMP_SECRET=generate-a-long-random-string

# --- App ---
# Public base URL of the deployed app (used in copy/paste instructions in the UI).
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
